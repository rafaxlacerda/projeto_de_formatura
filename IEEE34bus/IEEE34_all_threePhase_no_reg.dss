! 24.9/4.16 kV Transformer
New Transformer.XFM1  Phases=3 Windings=2 Xhl=4.08
~ wdg=1 bus=832  conn=wye  kv=24.9  kva=500  %r=0.95
~ wdg=2 bus=888  conn=Wye  kv=4.16  kva=500  %r=0.95

! LoadShapes
New LoadShape.Residencial npts=24 interval=1
~ mult=[0.175 0.175 0.175 0.175 0.175 0.175 0.200 0.375 0.600 0.600 0.600 0.600 0.375 0.375 0.250 0.325 0.325 0.425 0.925 0.950 1.000 0.775 0.425 0.325]

New LoadShape.Comercial npts=24 interval=1
~ mult=[0.300 0.300 0.325 0.350 0.400 0.450 0.600 0.750 0.900 0.925 0.950 0.925 0.900 0.750 0.675 0.500 0.500 0.500 0.725 0.750 0.600 0.500 0.325 0.325]

New LoadShape.Industrial npts=24 interval=1
~ mult=[0.325 0.325 0.350 0.375 0.375 0.375 0.500 0.750 1.250 1.750 1.750 1.750 1.500 1.000 1.000 0.750 0.550 0.475 0.475 0.475 0.450 0.425 0.350 0.325]

! Spot Loads
New Load.S860      Bus1=860  Phases=3 Conn=Wye  Model=1 kV=24.900 kW=60.0   kVAR=48.0   daily=Residencial vminpu=0.85
